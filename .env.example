# Environment variables for local development and production
# Copy this to .env.local for local development

# Node environment
NODE_ENV=development

# Application URL (for SEO and redirects)
NEXT_PUBLIC_APP_URL=https://cienfuegosglasscorp.com

# Optional: Contact form email settings (if you want to send real emails)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# CONTACT_EMAIL_FROM=noreply@cienfuegosglass.com
# CONTACT_EMAIL_TO=info@cienfuegosglass.com

# Optional: Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Optional: Sentry (error tracking)
# SENTRY_AUTH_TOKEN=your-sentry-token
